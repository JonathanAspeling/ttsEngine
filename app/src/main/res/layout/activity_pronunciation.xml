<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="10dp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:background="@drawable/rounded_solid"
        android:textColor="@color/white"
        android:textSize="18dp"
        android:text="@string/pronunciation_overrides" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/pronunciation_hint"
        android:textColor="@color/grey"
        android:textSize="12sp"
        android:paddingVertical="8dp" />

    <ListView
        android:id="@+id/pronunciation_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/button_add_pronunciation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/add_pronunciation"
        android:backgroundTint="@color/primaryDark"
        android:textColor="@color/white"
        android:layout_marginTop="8dp" />

</LinearLayout>
